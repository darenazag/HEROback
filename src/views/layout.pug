doctype html
html(lang='es')
  head
    meta(charset='UTF-8')
    meta(name='viewport', content='width=device-width, initial-scale=1.0, viewport-fit=cover')
    meta(name='theme-color', content='#0f0f1a')
    if jwtToken
      meta(name='jwt-token', content=jwtToken)
    title HEROback — #{title || 'Plataforma de Superhéroes'}
    link(rel='stylesheet', href='/styles.css')
    link(rel="icon" type="image/x-icon" href="/favicon.ico")
    block links
    block head
  body
    nav.navbar
      a.navbar-brand(href='/') ⚡ HEROback
      button.nav-toggle(type='button', aria-label='Abrir menú', aria-controls='nav-menu', aria-expanded='false', onclick="(function(b){var m=document.getElementById('nav-menu');var o=m.classList.toggle('open');b.setAttribute('aria-expanded',o);})(this)") ☰
      ul#nav-menu.nav-links
        li: a(href='/heroes') Héroes
        li: a(href='/store') Tienda
        if user
          li: a(href='/teams') Mis equipos
          li: a(href='/dashboard') Dashboard
          if user.role === 'admin'
            li: a.admin-link(href='/admin') ⚙ Admin
          li: a(href='/logout') Salir
        else
          li: a(href='/login') Iniciar sesión
          li: a(href='/register') Registrarse

    main.container
      block content

    footer.footer
      p &copy; 2026 HEROback — Proyecto Personal Backend

    script(src='/app.js')
    block scripts
