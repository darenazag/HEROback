doctype html
html(lang='es')
  head
    meta(charset='UTF-8')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    if jwtToken
      meta(name='jwt-token', content=jwtToken)
    title HEROback — #{title || 'Plataforma de Superhéroes'}
    link(rel='stylesheet', href='/styles.css')
    block head
  body
    nav.navbar
      a.navbar-brand(href='/') ⚡ HEROback
      ul.nav-links
        li: a(href='/heroes') Héroes
        li: a(href='/store') Tienda
        if user
          li: a(href='/teams') Mis equipos
          li: a(href='/dashboard') Dashboard
          if user.role === 'admin'
            li: a.admin-link(href='/admin') ⚙ Admin
          li: a(href='/logout') Salir
        else
          li: a(href='/login') Iniciar sesión
          li: a(href='/register') Registrarse

    main.container
      block content

    footer.footer
      p &copy; 2026 HEROback — Proyecto Backend

    script(src='/app.js')
    block scripts
